// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum InquiryStatus {
  NEW
  CONTACTED
  CLOSED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  INTERNSHIP
}

enum EventType {
  FIXED
  RECURRING
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

// ---------------------------------------------------------------------------
// Auth (internal admin accounts) — unchanged from the original project.
// ---------------------------------------------------------------------------

model AdminUser {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Site-wide settings (contact info, social links, etc.).
// ---------------------------------------------------------------------------

model SiteSetting {
  id    String @id @default(uuid())
  key   String @unique
  value String
}

// ---------------------------------------------------------------------------
// Public inbox: contact inquiries.
// ---------------------------------------------------------------------------

model Inquiry {
  id          String        @id @default(uuid())
  fullName    String
  email       String
  subject     String
  description String
  status      InquiryStatus @default(NEW)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

// ---------------------------------------------------------------------------
// Careers + public job applications.
// ---------------------------------------------------------------------------

model Career {
  id             String         @id @default(uuid())
  jobTitle       String
  department     String
  employmentType EmploymentType
  location       String
  description    String
  applications   Application[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Application {
  id        String   @id @default(uuid())
  fullName  String
  email     String
  careerId  String?
  career    Career?  @relation(fields: [careerId], references: [id], onDelete: SetNull)
  resumeUrl String // uploaded PDF path under /uploads/applications
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Merchandise.
// ---------------------------------------------------------------------------

model Merchandise {
  id               String   @id @default(uuid())
  image            String?
  name             String
  shortDescription String
  price            Decimal  @db.Decimal(12, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Articles (blog).
// ---------------------------------------------------------------------------

model ArticleCategory {
  id        String    @id @default(uuid())
  name      String
  articles  Article[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Article {
  id                String           @id @default(uuid())
  image             String?
  title             String
  slug              String           @unique
  shortDescription  String
  description       String // rich text (HTML)
  articleCategoryId String?
  articleCategory   ArticleCategory? @relation(fields: [articleCategoryId], references: [id], onDelete: SetNull)
  publishedDate     DateTime
  status            Int              @default(0) // 0 = Draft, 1 = Published
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

// ---------------------------------------------------------------------------
// Venues + their categories, segment galleries, talents.
// ---------------------------------------------------------------------------

model Category {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  image     String?
  caption   String
  venues    Venue[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Venue {
  id              String           @id @default(uuid())
  name            String
  slug            String           @unique
  description     String
  image           String?
  bannerImage     String?
  categoryId      String?
  category        Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  operatingHours  String
  location        String
  lat             Float?
  lng             Float?
  spotifyEmbed    String?
  youtubeEmbed    String?
  instagramEmbed  String?
  segmentGalleries SegmentGallery[]
  talents         Talent[]
  promotions      Promotion[]
  events          Event[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model SegmentGallery {
  id          String   @id @default(uuid())
  title       String
  description String
  images      String[] // multiple uploaded image paths, ordered
  special     Boolean  @default(false)
  venueId     String?
  venue       Venue?   @relation(fields: [venueId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Talent {
  id           String   @id @default(uuid())
  image        String?
  name         String
  speciality   String
  description  String
  venueId      String?
  venue        Venue?   @relation(fields: [venueId], references: [id], onDelete: SetNull)
  instagramUrl String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Promotions.
// ---------------------------------------------------------------------------

model Promotion {
  id               String   @id @default(uuid())
  image            String?
  bannerImage      String?
  posterImage      String?
  name             String
  slug             String   @unique
  shortDescription String
  description      String
  caption          String
  terms            String // rich text (HTML)
  venueId          String?
  venue            Venue?   @relation(fields: [venueId], references: [id], onDelete: SetNull)
  startDate        DateTime
  endDate          DateTime
  startHour        String // "HH:mm"
  endHour          String // "HH:mm"
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Events (fixed-date or recurring).
// ---------------------------------------------------------------------------

model EventCategory {
  id        String   @id @default(uuid())
  name      String
  events    Event[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Event {
  id               String         @id @default(uuid())
  image            String?
  bannerImage      String?
  posterImage      String?
  name             String
  slug             String         @unique
  shortDescription String
  description      String
  caption          String
  eventCategoryId  String?
  eventCategory    EventCategory? @relation(fields: [eventCategoryId], references: [id], onDelete: SetNull)
  venueId          String?
  venue            Venue?         @relation(fields: [venueId], references: [id], onDelete: SetNull)
  eventType        EventType      @default(FIXED)
  startDate        DateTime
  endDate          DateTime?
  startHour        String // "HH:mm"
  endHour          String // "HH:mm"
  recurringDays    Weekday[] // used when eventType = RECURRING
  featured         Boolean        @default(false)
  isPrivate        Boolean        @default(false) @map("private")
  galleries        String[] // multiple uploaded image paths, ordered
  ticketInfo       String?
  waPhone          String?
  ticketLink       String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

// ---------------------------------------------------------------------------
// Standalone galleries + videos.
// ---------------------------------------------------------------------------

model Gallery {
  id          String   @id @default(uuid())
  image       String?
  title       String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Video {
  id          String   @id @default(uuid())
  image       String?
  videoUrl    String // YouTube URL
  title       String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// FAQs.
// ---------------------------------------------------------------------------

model Faq {
  id        String   @id @default(uuid())
  question  String
  answer    String   // rich text (HTML)
  segment   String   @default("general")
  sortOrder Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Private events: the "Event Types" tiles + the "Moments We've Hosted" entries.
// (Model is PrivateEventType, not EventType — that name is the FIXED/RECURRING enum.)
// ---------------------------------------------------------------------------

model PrivateEventType {
  id            String         @id @default(uuid())
  image         String?
  title         String
  description   String
  sortOrder     Int            @default(0)
  published     Boolean        @default(true)
  privateEvents PrivateEvent[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model PrivateEvent {
  id                 String            @id @default(uuid())
  image              String?
  bannerImage        String?
  title              String
  slug               String            @unique
  caption            String
  shortDescription   String
  description        String
  privateEventTypeId String?
  privateEventType   PrivateEventType? @relation(fields: [privateEventTypeId], references: [id], onDelete: SetNull)
  sortOrder          Int               @default(0)
  published          Boolean           @default(true)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
}
